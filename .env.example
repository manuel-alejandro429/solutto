# ─────────────────────────────────────────
# Supabase (apps/web)
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # NEVER expose to the browser

# ─────────────────────────────────────────
# Admin panel (apps/web)
# ─────────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=                   # generate: openssl rand -base64 32

# ─────────────────────────────────────────
# Security (apps/web)
# ─────────────────────────────────────────
PHONE_HASH_SALT=                  # generate: openssl rand -base64 32 — NEVER change after launch

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://solutto.co
